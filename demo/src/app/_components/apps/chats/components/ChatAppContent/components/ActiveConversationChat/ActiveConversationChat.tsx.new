import React from "react";
import { Box, Chip, Typography } from "@mui/material";
import { format, isToday, isYesterday } from "date-fns";
import { SentMessageContent } from "../SentMessageContent";
import { ReceivedMessageContent } from "../ReceivedMessageContent";
import { MessagesProps } from "@app/_components/apps/_types/ChatTypes";

// Extend MessagesProps with our additional fields
type ExtendedMessageProps = Omit<MessagesProps, 'sent_at' | 'timestamp' | 'createdAt' | 'content'> & {
  _id?: string;
  status?: 'sending' | 'sent' | 'delivered' | 'read' | 'error';
  timestamp?: string | Date;
  createdAt?: string | Date;
  sent_at?: string | Date;
  read?: boolean;
  content: string;
};

interface ActiveConversationChatProps {
  conversation: {
    messages: ExtendedMessageProps[];
    sent_date?: string;
  };
  activeConversation: {
    contact?: {
      id: string;
      name: string;
      avatar?: string;
    };
  };
  currentUserId: string;
  loading?: boolean;
}

const formatGroupDate = (date: Date): string => {
  if (isToday(date)) return 'Today';
  if (isYesterday(date)) return 'Yesterday';
  return format(date, 'EEEE, MMMM d, yyyy');
};

const ActiveConversationChat: React.FC<ActiveConversationChatProps> = ({
  conversation,
  activeConversation,
  currentUserId,
  loading = false
}) => {
  const remoteUser = activeConversation?.contact;
  const messagesContainerRef = React.useRef<HTMLDivElement>(null);
  
  // Memoize and sort messages by timestamp
  const messages = React.useMemo(() => {
    return (conversation?.messages || []).sort((a, b) => {
      const getTime = (msg: ExtendedMessageProps): number => {
        const time = msg.timestamp || msg.createdAt || msg.sent_at;
        return time ? new Date(time).getTime() : 0;
      };
      return getTime(a) - getTime(b);
    });
  }, [conversation?.messages]);

  // Group messages by date
  const groupedMessages = React.useMemo(() => {
    const groups: {[key: string]: ExtendedMessageProps[]} = {};
    
    messages.forEach((message) => {
      const date = message.timestamp || message.createdAt || message.sent_at || new Date();
      const dateKey = format(new Date(date), 'yyyy-MM-dd');
      
      if (!groups[dateKey]) {
        groups[dateKey] = [];
      }
      
      groups[dateKey].push(message);
    });
    
    return Object.entries(groups);
  }, [messages]);
  
  // Auto-scroll to bottom when new messages arrive
  React.useEffect(() => {
    if (messagesContainerRef.current) {
      messagesContainerRef.current.scrollTop = messagesContainerRef.current.scrollHeight;
    }
  }, [messages]);
  
  // Loading state
  if (loading) {
    return (
      <Box sx={{ p: 3, textAlign: 'center' }}>
        <Typography color="text.secondary">Loading messages...</Typography>
      </Box>
    );
  }
  
  // Empty state
  if (messages.length === 0) {
    return (
      <Box sx={{ p: 3, textAlign: 'center' }}>
        <Typography color="text.secondary">No messages yet. Start the conversation!</Typography>
      </Box>
    );
  }

  return (
    <Box
      ref={messagesContainerRef}
      sx={{
        flex: 1,
        overflowY: 'auto',
        p: 2,
        display: 'flex',
        flexDirection: 'column',
        gap: 2
      }}
    >
      {groupedMessages.map(([date, dateMessages]) => {
        const messageDate = new Date(date);
        
        return (
          <Box key={date} sx={{ display: 'flex', flexDirection: 'column', gap: 2 }}>
            {/* Date separator */}
            <Box sx={{ display: 'flex', justifyContent: 'center', my: 1 }}>
              <Chip
                label={formatGroupDate(messageDate)}
                size="small"
                sx={{
                  bgcolor: 'background.paper',
                  color: 'text.secondary',
                  fontSize: '0.75rem',
                  px: 1,
                  height: 'auto',
                  '& .MuiChip-label': { p: 0.5 }
                }}
              />
            </Box>
            
            {/* Messages for this date */}
            {dateMessages.map((message) => {
              const isOwnMessage = String(message.sent_by) === String(currentUserId);
              const senderName = isOwnMessage ? 'You' : (remoteUser?.name || 'Unknown');
              const senderAvatar = isOwnMessage ? undefined : remoteUser?.avatar;
              
              return isOwnMessage ? (
                <SentMessageContent
                  key={message._id || message.id || Math.random().toString(36).substr(2, 9)}
                  message={{
                    content: message.content,
                    timestamp: message.timestamp,
                    sent_at: message.sent_at,
                    read: message.read
                  }}
                  senderName={senderName}
                  status={message.status || 'delivered'}
                />
              ) : (
                <ReceivedMessageContent
                  key={message._id || message.id || Math.random().toString(36).substr(2, 9)}
                  message={{
                    content: message.content,
                    timestamp: message.timestamp,
                    sent_at: message.sent_at,
                    read: message.read
                  }}
                  senderName={senderName}
                  senderAvatar={senderAvatar}
                />
              );
            })}
          </Box>
        );
      })}
    </Box>
  );
};

export { ActiveConversationChat };
